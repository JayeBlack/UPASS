# ============================================================
# UMaT Postgrad Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# ============================================================

# ── Server ──
PORT=5000
NODE_ENV=development

# ── PostgreSQL Database ──
DATABASE_URL=postgresql://username:password@localhost:5432/umat_postgrad_db

# ── JWT Authentication ──
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=24h

# ── Chatbot / AI Gateway ──
# The chatbot runs as a separate service but can optionally be proxied
# through this backend. Set CHATBOT_SERVICE_URL to the chatbot's address.
#
# Option A: Chatbot runs as a standalone service (recommended for production)
CHATBOT_SERVICE_URL=http://localhost:5001
#
# Option B: Use an AI gateway directly (e.g., OpenAI, Gemini)
# AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1/chat/completions
# AI_GATEWAY_API_KEY=your_ai_gateway_key
#
# The frontend should point to:
#   VITE_API_URL=http://localhost:5000/api  (this backend)
#   VITE_CHATBOT_URL=http://localhost:5001  (or http://localhost:5000/api/chatbot if proxied)

# ── File Uploads ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── CORS ──
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend Config (for reference — set these in frontend .env) ──
# VITE_API_URL=http://localhost:5000/api
# VITE_CHATBOT_URL=http://localhost:5001
